{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		},
		"includes": [
			"**",
			"!**/dist",
			"!**/*.bs.js",
			"!**/lib",
			"!**/__generated__"
		]
	},
	"formatter": {
		"enabled": true,
		"includes": [
			"**",
			"!**/dist",
			"!**/*.bs.js",
			"!**/lib",
			"!**/__generated__"
		]
	}
}
